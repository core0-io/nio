{
  "name": "@core0-io/ffwd-agent-guard",
  "version": "1.0.12",
  "description": "FFWD AgentGuard — Security guard for AI agents. Blocks dangerous commands, prevents data leaks, protects secrets. 16 detection rules, runtime action evaluation, trust registry.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/adapters/openclaw-plugin.js"
    ]
  },
  "bin": {
    "ffwd-agent-guard": "./dist/mcp-server.js"
  },
  "scripts": {
    "prebuild": "cp package.json pnpm-lock.yaml skills/ffwd-agent-guard/ && cd skills/ffwd-agent-guard && pnpm install --prod --frozen-lockfile --node-linker=hoisted && rm package.json pnpm-lock.yaml",
    "build": "rm -rf dist && tsc && tsc -p tsconfig.scripts.json && node scripts/add-banner.js && node_modules/.bin/esbuild dist/adapters/openclaw-plugin.js --bundle --platform=node --format=esm --outfile=openclaw-plugin/plugin.js --external:node:*",
    "start": "node dist/mcp-server.js",
    "dev": "tsc -w & tsc -w -p tsconfig.scripts.json",
    "test": "node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code-skill",
    "agent-skills",
    "mcp",
    "security",
    "ai-agent",
    "ffwd-agent-guard",
    "claude-code",
    "codex",
    "scanner",
    "trust-registry",
    "hooks"
  ],
  "author": "core0-io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/core0-io/ffwd-agent-guard.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@grpc/grpc-js": "^1.14.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "axios": "^1.6.7",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "homepage": "https://github.com/core0-io/ffwd-agent-guard#readme",
  "bugs": {
    "url": "https://github.com/core0-io/ffwd-agent-guard/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "openclaw.plugin.json",
    "skills"
  ],
  "type": "module"
}
