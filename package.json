{
  "name": "@core0-io/ffwd-agent-guard",
  "version": "1.0.12",
  "description": "FFWD AgentGuard — Security and observability for AI coding agents. Dynamic guard, static scan, OTEL collector.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/adapters/openclaw-plugin.js"
    ]
  },
  "scripts": {
    "prebuild": "cp package.json pnpm-lock.yaml plugins/claude-code/skills/ffwd-agent-guard/ && cd plugins/claude-code/skills/ffwd-agent-guard && pnpm install --prod --frozen-lockfile --node-linker=hoisted && rm package.json pnpm-lock.yaml",
    "build": "rm -rf dist && tsc -p tsconfig.lib.json && tsc -p tsconfig.scripts.json && node scripts/add-banner.js && node_modules/.bin/esbuild dist/adapters/openclaw-plugin.js --bundle --platform=node --format=esm --outfile=plugins/openclaw/plugin.js --external:node:* && node scripts/sync-shared.js",
    "dev": "tsc -w -p tsconfig.lib.json & tsc -w -p tsconfig.scripts.json",
    "test": "node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build",
    "release": "node scripts/release.js all",
    "release:claude-code": "node scripts/release.js claude-code",
    "release:openclaw": "node scripts/release.js openclaw",
    "release:publish": "node scripts/release.js all && gh release create v$npm_package_version releases/*.zip --title \"v$npm_package_version\" --generate-notes"
  },
  "keywords": [
    "claude-code-skill",
    "agent-skills",
    "security",
    "ai-agent",
    "ffwd-agent-guard",
    "claude-code",
    "codex",
    "scanner",
    "otel",
    "hooks"
  ],
  "author": "core0-io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/core0-io/ffwd-agent-guard.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@grpc/grpc-js": "^1.14.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "axios": "^1.6.7",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "homepage": "https://github.com/core0-io/ffwd-agent-guard#readme",
  "bugs": {
    "url": "https://github.com/core0-io/ffwd-agent-guard/issues"
  },
  "files": [
    "dist",
    "README.md",
    "plugins/openclaw/openclaw.plugin.json",
    "plugins/claude-code/skills"
  ],
  "type": "module"
}
